{
  "name": "cities",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "docs:check": "npx tsx scripts/docs-validate.ts",
    "depcruise": "depcruise src",
    "depcruise:graph": "depcruise src --output-type dot | dot -T svg > docs/dependency-graph.svg",
    "prepare": "husky"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.174.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@eslint/js": "^9.24.0",
    "@playwright/test": "^1.61.0",
    "@types/three": "^0.174.0",
    "@vitest/coverage-v8": "^3.2.6",
    "dependency-cruiser": "^17.4.3",
    "eslint": "^9.24.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "knip": "^6.17.1",
    "lint-staged": "^15.5.1",
    "prettier": "^3.5.3",
    "remark-cli": "^12.0.1",
    "remark-validate-links": "^13.1.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.2",
    "vitest": "^3.1.1"
  },
  "lint-staged": {
    "*.{ts,js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,html,css}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20"
  }
}
